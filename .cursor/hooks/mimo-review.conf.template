# MiMo Review Hook — Configuration
# Copy this file and rename to mimo-review.conf (no .template suffix)
# then fill in your API key.
#
# All values are optional; defaults are shown below.

# Review mode: "api" (recommended) or "cli"
MIMO_MODE=api

# MiMo API key (required for api mode)
# Get yours from: https://platform.xiaomimimo.com
MIMO_API_KEY=sk-your-key-here

# API endpoint (OpenAI-compatible)
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Model to use
MIMO_MODEL=mimo-v2.5-pro
